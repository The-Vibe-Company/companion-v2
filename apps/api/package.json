{
  "name": "@companion/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed:test-user": "tsx src/seed-test-user.ts",
    "build": "tsup && node scripts/copy-migrations.cjs",
    "migrate": "node dist/migrate.js",
    "start": "node dist/migrate.js && node dist/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "test:integration": "COMPANION_INTEGRATION_TESTS=1 vitest run --config vitest.integration.config.ts --exclude test/integration/rls.integration.test.ts && COMPANION_INTEGRATION_TESTS=1 COMPANION_DATABASE_POOL_MAX=1 vitest run --config vitest.integration.config.ts test/integration/rls.integration.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@companion/auth": "workspace:*",
    "@companion/billing": "workspace:*",
    "@companion/companion-skill": "workspace:*",
    "@companion/contracts": "workspace:*",
    "@companion/core": "workspace:*",
    "@companion/db": "workspace:*",
    "@companion/email": "workspace:*",
    "@companion/sandbox": "workspace:*",
    "@companion/skills": "workspace:*",
    "@companion/storage": "workspace:*",
    "@hono/node-server": "^1.18.2",
    "@trpc/server": "^10.45.2",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hono": "^4.12.30",
    "postgres": "^3.4.5",
    "resend": "^6.17.2",
    "stripe": "^18.5.0",
    "tar-stream": "^3.1.7",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "3.2.7"
  }
}
