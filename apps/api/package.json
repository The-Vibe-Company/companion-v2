{
  "name": "@companion/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed:test-user": "tsx src/seed-test-user.ts",
    "build": "tsup && node scripts/copy-migrations.cjs",
    "migrate": "node dist/migrate.js",
    "start": "node dist/migrate.js && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.4",
    "@companion/auth": "workspace:*",
    "@companion/contracts": "workspace:*",
    "@companion/core": "workspace:*",
    "@companion/db": "workspace:*",
    "@companion/email": "workspace:*",
    "@companion/skills": "workspace:*",
    "@companion/storage": "workspace:*",
    "@hono/node-server": "^1.18.2",
    "@trpc/server": "^10.45.2",
    "better-auth": "^1.6.4",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.10.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
