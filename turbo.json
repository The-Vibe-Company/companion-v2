{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "BETTER_AUTH_URL",
        "COMPANION_API_URL",
        "COMPANION_WEB_URL",
        "NEXT_PUBLIC_COMPANION_API_BASE",
        "NEXT_PUBLIC_COMPANION_API_URL",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "coverage": {
      "cache": false,
      "outputs": ["coverage/**"]
    }
  }
}
