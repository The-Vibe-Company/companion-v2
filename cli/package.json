{
  "name": "@companion/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "companion": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@companion/contracts": "workspace:*",
    "@companion/skills": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "tar-stream": "^3.1.7",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/tar-stream": "^3.1.3",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "3.2.7"
  }
}
