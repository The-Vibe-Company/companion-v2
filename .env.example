# Companion v2 — environment template. Copy to .env.local (web) / .env (cli) and fill in.
# Local values come from `supabase start` (the CLI prints the anon key + service role key).

# --- Supabase (public; safe to expose to the browser) ----------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only; NEVER ship to the browser or the CLI) ----------
# Used only by trusted server routes (e.g. minting signed download URLs).
SUPABASE_SERVICE_ROLE_KEY=

# --- CLI defaults ----------------------------------------------------------
# The CLI reads these as fallbacks; `companion login --api-url` overrides them.
COMPANION_SUPABASE_URL=http://127.0.0.1:54321
COMPANION_SUPABASE_ANON_KEY=
