# Companion v2 local environment.

# --- API / web --------------------------------------------------------------
COMPANION_API_URL=http://127.0.0.1:3001
COMPANION_WEB_URL=http://127.0.0.1:3000
NEXT_PUBLIC_COMPANION_API_URL=http://127.0.0.1:3001
# Optional PostHog web analytics. Get these from the PostHog project settings.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# In production set BETTER_AUTH_URL to the API's public origin — the Google OAuth callback URL is
# derived from it (${BETTER_AUTH_URL}/auth/callback/google) and must be registered with Google.
BETTER_AUTH_URL=http://127.0.0.1:3001
BETTER_AUTH_COOKIE_PREFIX=better-auth
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret

# --- Google OAuth (Better Auth social provider) -----------------------------
# Optional: the "Continue with Google" button always renders, but Google sign-in is only wired when
# both are set. Authorized redirect URI to register in Google Cloud: ${BETTER_AUTH_URL}/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Postgres ---------------------------------------------------------------
DATABASE_URL=postgres://companion:companion@127.0.0.1:5432/companion
COMPOSE_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432

# --- S3-compatible storage (MinIO locally) ---------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=companion
S3_SECRET_ACCESS_KEY=companion-secret
S3_BUCKET_SKILL_ARCHIVES=skill-archives
S3_FORCE_PATH_STYLE=true

# --- Email ------------------------------------------------------------------
# Verification + password-reset codes and org invites are sent through this provider. Use "mailpit"
# (read codes in the Mailpit UI) or "log" (console) locally; set "resend" + RESEND_API_KEY in production.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=Companion <noreply@companion.local>
MAILPIT_SMTP_HOST=127.0.0.1
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
RESEND_API_KEY=

# --- Companion Agents (OpenCode in Vercel Sandbox) ---------------------------
# Sandbox provisioning talks to the real Vercel API; all three are required to create agents.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
# Printed by `pnpm --filter @companion/sandbox golden` (run once per OPENCODE_VERSION).
COMPANION_GOLDEN_SNAPSHOT_ID=
# Exact OpenCode pin (releases are near-daily with breaking changes; keep in lockstep with
# @opencode-ai/sdk in packages/sandbox/package.json).
OPENCODE_VERSION=1.17.13
# base64 32-byte master key sealing agent secrets + server passwords (generate: openssl rand -base64 32).
COMPANION_SECRETS_KEY=
# Sandbox inactivity timeout (ms) — drives the derived running|sleeping status.
COMPANION_SANDBOX_TIMEOUT_MS=300000
# Model provider keys. Their PRESENCE controls which models the create-agent picker offers
# (models.dev catalog, tool-capable only); the chosen model's key is injected into the sandbox.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
