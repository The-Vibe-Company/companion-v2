# Companion v2 local environment.

# --- API / web --------------------------------------------------------------
COMPANION_API_URL=http://127.0.0.1:3001
COMPANION_WEB_URL=http://127.0.0.1:3000
NEXT_PUBLIC_COMPANION_API_URL=http://127.0.0.1:3001
BETTER_AUTH_URL=http://127.0.0.1:3001
BETTER_AUTH_COOKIE_PREFIX=better-auth
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret

# --- Postgres ---------------------------------------------------------------
DATABASE_URL=postgres://companion:companion@127.0.0.1:5432/companion
COMPOSE_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432

# --- S3-compatible storage (MinIO locally) ---------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=companion
S3_SECRET_ACCESS_KEY=companion-secret
S3_BUCKET_SKILL_ARCHIVES=skill-archives
S3_FORCE_PATH_STYLE=true

# --- Email ------------------------------------------------------------------
EMAIL_PROVIDER=mailpit
EMAIL_FROM=Companion <noreply@companion.local>
MAILPIT_SMTP_HOST=127.0.0.1
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
RESEND_API_KEY=
