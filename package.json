{
  "name": "companion-v2",
  "version": "0.0.0",
  "private": true,
  "description": "Companion v2 — self-hostable portal to deploy, govern, and share AI agents, containers, and skills.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "compose:up": "docker compose up -d postgres minio mailpit minio-init",
    "compose:down": "docker compose down",
    "db:generate": "pnpm --filter @companion/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @companion/db drizzle-kit migrate",
    "db:seed": "pnpm --filter @companion/db seed",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "browser:smoke": "bash scripts/agent-browser-smoke.sh",
    "cli": "pnpm --filter @companion/cli exec companion",
    "design:lint": "npx --yes @google/design.md@0.2.0 lint DESIGN.md --format json"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
