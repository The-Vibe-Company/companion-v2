{
  "name": "companion-v2",
  "version": "0.0.0",
  "private": true,
  "description": "Companion v2 — self-hostable portal to deploy, govern, and share AI agents, containers, and skills.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.16": "1.1.16",
      "brace-expansion@>=3.0.0 <5.0.7": "5.0.7",
      "js-yaml@>=4.0.0 <4.3.0": "4.3.0",
      "postcss": "8.5.15",
      "sharp": "0.35.3",
      "vite": "6.4.3",
      "shell-quote": "1.10.0"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "compose:up": "docker compose up -d postgres minio mailpit minio-init",
    "compose:down": "docker compose down",
    "db:generate": "pnpm --filter @companion/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @companion/db drizzle-kit migrate",
    "db:seed": "pnpm --filter @companion/db seed",
    "dev": "bash scripts/dev-stack.sh",
    "dev:conductor": "bash scripts/dev-conductor.sh",
    "dev:app": "pnpm exec concurrently -k -n api,worker,web \"COMPANION_API_HOST=${COMPANION_API_HOST:-127.0.0.1} pnpm --filter @companion/api dev\" \"bash scripts/dev-worker.sh pnpm --filter @companion/worker dev\" \"pnpm --filter @companion/web dev --hostname ${COMPANION_WEB_HOST:-127.0.0.1} --port ${COMPANION_WEB_PORT:-3000}\"",
    "dev:check": "bash scripts/dev-stack-check.sh",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run coverage",
    "test:integration": "pnpm --filter @companion/api test:integration",
    "test:e2e": "node scripts/ci-playwright-policy.mjs && playwright test",
    "ci:quality": "turbo run lint typecheck test --continue=dependencies-successful",
    "verify:change": "node scripts/verify-change.mjs",
    "browser:smoke": "bash scripts/agent-browser-smoke.sh",
    "smoke:api": "bash scripts/ci-api-smoke.sh",
    "smoke:rsc": "bash scripts/ci-rsc-smoke.sh",
    "cli": "pnpm --filter @companion/cli exec companion",
    "design:lint": "npx --yes @google/design.md@0.2.0 lint DESIGN.md --format json"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "3.2.7",
    "concurrently": "^9.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
