{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @companion/api build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @companion/api migrate",
    "startCommand": "node apps/api/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 15
  }
}
