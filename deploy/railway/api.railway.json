{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/railway/Dockerfile.backend",
    "watchPatterns": [
      "/.dockerignore",
      "/apps/api/**",
      "/packages/**",
      "/deploy/railway/Dockerfile.backend",
      "/deploy/railway/api.railway.json",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "node dist/migrate.js",
    "startCommand": "node dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 15
  }
}
