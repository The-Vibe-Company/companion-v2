{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/railway/Dockerfile.backend",
    "watchPatterns": [
      "/.dockerignore",
      "/apps/worker/**",
      "/packages/billing/**",
      "/packages/contracts/**",
      "/packages/core/**",
      "/packages/db/**",
      "/packages/sandbox/**",
      "/packages/skills/**",
      "/packages/storage/**",
      "/deploy/railway/Dockerfile.backend",
      "/deploy/railway/worker.railway.json",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "restartPolicyType": "ALWAYS",
    "drainingSeconds": 15
  }
}
