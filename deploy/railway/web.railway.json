{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/railway/Dockerfile.web",
    "watchPatterns": [
      "/.dockerignore",
      "/apps/web/**",
      "/packages/contracts/**",
      "/packages/core/**",
      "/packages/db/**",
      "/packages/billing/**",
      "/packages/skills/**",
      "/deploy/railway/Dockerfile.web",
      "/deploy/railway/web.railway.json",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "node apps/web/server.js",
    "healthcheckPath": "/login",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 15
  }
}
