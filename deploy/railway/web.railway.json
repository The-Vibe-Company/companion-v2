{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @companion/web build",
    "watchPatterns": [
      "/apps/web/**",
      "/packages/contracts/**",
      "/packages/core/**",
      "/packages/skills/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @companion/web start --hostname 0.0.0.0 --port $PORT",
    "healthcheckPath": "/login",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 15
  }
}
